{
  "name": "@braudypedrosa/bp-listings",
  "version": "1.0.5",
  "description": "Airbnb-style listings + map widget powered by vanilla JavaScript and Leaflet",
  "main": "./listings-map.js",
  "exports": {
    ".": "./listings-map.js",
    "./styles": "./listings-map.css"
  },
  "files": [
    "listings-map.js",
    "listings-map.css",
    "listings-map.scss",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "listings",
    "leaflet",
    "map",
    "vacation-rental",
    "widget"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braudypedrosa/bp-listings.git"
  },
  "bugs": {
    "url": "https://github.com/braudypedrosa/bp-listings/issues"
  },
  "homepage": "https://github.com/braudypedrosa/bp-listings#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:css": "sass listings-map.scss listings-map.css --no-source-map --style=expanded",
    "dev": "vite",
    "test": "vitest run --environment jsdom",
    "release": "npm run build:css && bash ./scripts/release.sh",
    "release:patch": "bash ./scripts/release.sh patch",
    "release:minor": "bash ./scripts/release.sh minor",
    "release:major": "bash ./scripts/release.sh major",
    "release:npm": "npm publish"
  },
  "devDependencies": {
    "@braudypedrosa/bp-calendar": "^1.0.3",
    "@braudypedrosa/bp-search-widget": "^1.0.1",
    "jsdom": "^28.1.0",
    "sass-embedded": "^1.97.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
